{
  "name": "web-launch-kit",
  "version": "0.0.1",
  "description": "TypeScript library for launching external apps and communication intents from the web — deep links / custom schemes, tel, sms, and mailto, with graceful store/web fallbacks.",
  "author": "Park Jungyoung <qkrwnss0509@gmail.com> (https://github.com/pjy0509)",
  "type": "module",
  "sideEffects": false,
  "main": "dist/launch-kit.cjs",
  "module": "dist/launch-kit.mjs",
  "browser": "dist/launch-kit.umd.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/launch-kit.mjs",
      "require": "./dist/launch-kit.cjs",
      "default": "./dist/launch-kit.mjs"
    }
  },
  "files": [
    "dist/**",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pjy0509/web-launch-kit.git"
  },
  "homepage": "https://pjy0509.github.io/example/web-launch-kit/",
  "keywords": [
    "deep-link",
    "deeplink",
    "universal-link",
    "app-link",
    "custom-scheme",
    "intent",
    "launch",
    "open-app",
    "tel",
    "sms",
    "mailto",
    "browser",
    "webview",
    "pwa"
  ],
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.52.5",
    "rollup-plugin-dts": "^6.2.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "web-locale-kit": "^0.0.4",
    "web-platform-kit": "^0.0.4"
  }
}
